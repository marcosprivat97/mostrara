# Core app
APP_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
SESSION_SECRET=your_session_secret_here
BASE_PATH=/
PORT=23131
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:23131/api
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Database
DATABASE_URL=postgresql://user:password@host:port/database

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Resend
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=your_verified_sender_email

# Mercado Pago
MP_CLIENT_ID=your_client_id_here
MP_CLIENT_SECRET=your_client_secret_here
MP_REDIRECT_URI=http://localhost:23131/api/auth/mercadopago/callback
MP_STATE_SECRET=your_mp_state_secret_here
MP_TOKEN_ENCRYPTION_SECRET=your_mp_token_encryption_secret_here
MP_WEBHOOK_SECRET=your_mp_webhook_secret_here

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:23131/api/auth/google/callback
GOOGLE_OAUTH_STATE_SECRET=your_google_state_secret_here

# AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
AI_DAILY_LIMIT=40

# LogSnag
LOGSNAG_TOKEN=your_logsnag_token_here
LOGSNAG_PROJECT=mostrara

# Admin
ADMIN_EMAILS=admin@example.com

# PostHog
VITE_POSTHOG_KEY=your_posthog_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry
VITE_SENTRY_DSN=
